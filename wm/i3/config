### i3-gaps stuff ###

# Necessary for i3-gaps to work properly (pixel can be any value)
for_window [class="^.*"] border pixel 0

# Smart Gaps
# smart_gaps on

# Smart Borders
smart_borders on

# Set inner/outer gaps
gaps inner 15
gaps outer 20


# Startup Environment
exec xrandr --dpi 104 # set DPI to match monitor
exec_always --no-startup-id xrdb -load ~/.Xresources # make sure Xresources gets loaded
exec_always --no-startup-id xmodmap ~/.Xmodmap
exec_always --no-startup-id ~/.config/polybar/launch.sh
exec --no-startup-id  ~/.scripts/natural-scroll.sh # set Natural Scrolling
#exec --no-startup-id bash ~/.scripts/pa.sh
exec --no-startup-id picom -f --experimental-backends
exec --no-startup-id feh --bg-fill ~/Pictures/Wallpapers/space-mars-4480x2520-nordified.jpg

# Gnome+i3 stuff (https://github.com/csxr/i3-gnome/wiki/Tips-&-Tricks)
exec --no-startup-id /usr/lib/gsd-xsettings
exec_always --no-startup-id gnome-power-manager
exec --no-startup-id /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1
exec --no-startup-id gnome-flashback
